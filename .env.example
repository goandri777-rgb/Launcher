# ═══════════════════════════════════════════════════════════════════════════
#  ALAS Launcher — Variables de entorno
#  Copiar como .env y completar con valores reales. NUNCA commitear .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────────────────
# La anon key es pública por diseño; la seguridad real la da RLS, no esta clave.
# NUNCA pongas aquí la service_role key.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu-anon-key-publica

# ── SSO ─────────────────────────────────────────────────────────────────────
# Secreto HMAC-SHA-256 para firmar tokens SSO entre sistemas.
# Generar: node -e "require('crypto').randomBytes(32).toString('hex')"
# ⚠️  Debe ser IDÉNTICO en CajaVenta (js/alas-sso-config.js)
#       y Calendario (sso-config.js).
# ⚠️  Vite incrusta este valor en el bundle de producción (comportamiento
#       esperado de Vite). Para máxima seguridad, mover a Edge Function.
VITE_SSO_SECRET=tu-secreto-de-64-chars-aqui

# ── URLs del Launcher y módulos ─────────────────────────────────────────────
# URL pública del Launcher — usada por subsistemas para redirigir al login.
# Desarrollo: http://localhost:5173
# Producción: URL de Vercel (ej. https://alas-launcher.vercel.app)
VITE_LAUNCHER_URL=https://TU-LAUNCHER.vercel.app

# URLs de los módulos en producción.
# Dejar vacío si el módulo aún no está desplegado.
# En producción con DEMO_MODE=false, la URL real viene del RPC open_module de Supabase.
VITE_URL_CALENDARIO=https://TU-CALENDARIO.vercel.app
VITE_URL_PEDIDOS=https://TU-CAJAVENTA.vercel.app
VITE_URL_ACUSES=
VITE_URL_BORRADOS=
VITE_URL_RECEPCION=
VITE_URL_INVENTARIO=
